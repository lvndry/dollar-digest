# Database (Turso). Leave unset to use the local SQLite file (digest.db).
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_RESEND_KEY=re_your_resend_api_key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Public URL (used for JSON-LD and OG tags)
NEXT_PUBLIC_BASE_URL=https://www.onedollardigest.com

# Ingest endpoint protection — required to POST to /api/articles/ingest
INGEST_SECRET=generate-with-openssl-rand-hex-32
